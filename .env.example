# ──────────────────────────────────────────────────────────
# ARIA — Environment Variables
# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored and MUST NEVER be committed.
# ──────────────────────────────────────────────────────────

# Anthropic — server-side only (no NEXT_PUBLIC_ prefix)
# TODO: Verify model IDs at build time:
#   Haiku: claude-haiku-4-5-20251001
#   Sonnet: claude-sonnet-4-6
ANTHROPIC_API_KEY=sk-ant-...

# Supabase — anon key and URL are safe to expose (RLS protects data)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Supabase service role — server-side only (bypasses RLS — AD-13)
# ONLY used in scheduler/system Edge Functions, never in request handlers
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Zalo OA — server-side only (AD-11)
ZALO_OA_APP_ID=
ZALO_OA_APP_SECRET=
# Zalo refresh token is stored encrypted in DB (settings table), not in env

# SMTP / Email fallback — server-side only (AD-11)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
